{
    "name": "bleeding-deacons/unity",
    "description": "An intergroup management plugin for WordPress",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "authors": [
        {
            "name": "The Bleeding Deacons"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "10up/wp_mock": "^1.0",
        "mockery/mockery": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^9.6|^10.0",
        "squizlabs/php_codesniffer": "^3.6",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Unity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Unity\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": "php build.php build:production",
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:coverage": "phpunit --coverage-html ./tests/coverage",
        "cs": "phpcs --standard=WordPress ./src",
        "cs:fix": "phpcbf --standard=WordPress ./src",
        "stan": "phpstan analyse -l 5 ./src",
        "analyse": "phpstan analyse src/",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ],
        "phpstan": "phpstan analyse"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
